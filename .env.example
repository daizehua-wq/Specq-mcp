# SpecQ MCP Server 配置文件 v2.0
# 复制此文件为 .env 并修改

# MCP Server 自身认证
SPECQ_MCP_API_KEY=***

# FastAPI 后端地址（内部调用）
SPECQ_MCP_BASE_URL=http://localhost:8000

# 数据目录（ChromaDB + 工作记忆文件）
SPECQ_DATA_DIR=/home/ubuntu/specq_data

# LLM 配置（用于 extract_insights 暗知识结构化）
LLM_API_KEY=***
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Embedding 配置（用于 specq_memory 语义搜索）
# 支持任何兼容 OpenAI embedding 格式的 API
# 例如：智谱 embedding-2、DeepSeek embed、OpenAI text-embedding-3 等
EMBEDDING_API_KEY=***
EMBEDDING_API_URL=https://open.bigmodel.cn/api/paas/v4/embeddings
EMBEDDING_MODEL=embedding-2

# 联网搜索配置（用于 specq_search，可选）
SEARCH_API_KEY=***
