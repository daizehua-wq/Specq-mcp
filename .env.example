# SpecQ MCP Server 配置文件 v2.2
# 复制此文件为 .env 并填写

# LLM 配置（必需）
LLM_API_KEY=<your-api-key>
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Embedding（可选，用于语义记忆搜索）
# 留空则使用 LLM_API_KEY 对应的 API
EMBEDDING_API_KEY=
EMBEDDING_API_URL=https://api.deepseek.com/v1/embeddings
EMBEDDING_MODEL=deepseek-embed

# 数据目录（ChromaDB + 工作记忆文件）
SPECQ_DATA_DIR=~/.specq_data
